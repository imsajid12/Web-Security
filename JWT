# WRONG — kid used as file path
key = open(f"/keys/{kid}.pem").read()

# CORRECT — server-side map, kid never touches query/path
KEY_MAP = {
    "key-2024-01": load_key("key-2024-01.pem"),
    "key-2024-04": load_key("key-2024-04.pem"),
}
if kid not in KEY_MAP:
    raise ValueError("Unknown key ID")
key = KEY_MAP[kid]
