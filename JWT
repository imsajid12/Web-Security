Token revocation with denylist
# On issue — generate unique jti
import secrets as s
payload = {
    "sub": user_id,
    "jti": s.token_hex(16),  # unique per token
    "exp": ...,
}

# On logout — add jti to denylist (Redis recommended)
redis_client.setex(f"denylist:{jti}", ttl_seconds, "1")

# On verify — check denylist before accepting
if redis_client.get(f"denylist:{payload['jti']}"):
    raise ValueError("Token revoked")


Short lived tokens +  refresh tokens
# Access token: short lived (15 minutes)
access_token = jwt.encode(
    {"sub": uid, "exp": now + timedelta(minutes=15)}, SECRET)

# Refresh token: longer lived, stored server-side
refresh_token = secrets.token_hex(32)
db.store_refresh_token(uid, refresh_token, expires=now + timedelta(days=30))

# On refresh: validate refresh token in DB, issue new access token
# On logout: delete refresh token from DB
# Access token expires naturally — no denylist needed for 15min tokens


kid parameter safe handling
